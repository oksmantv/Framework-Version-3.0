		class Item23
		{
			dataType="Comment";
			class PositionInfo
			{
				position[]={24495.762,-19.944931,10749.679};
			};
			title="Strongpoints Locations";
			description="All these location logics are strongpoint definitions for dynamic scripts. If you have static infantry contacts in the array, they will spread among the strongpoints defined. If not defined they will automatically find towns.";
			id=1779;
			atlOffset=166.0461;
		};
		class Item24
		{
			dataType="Comment";
			class PositionInfo
			{
				position[]={24700.578,-20.931595,10936.938};
			};
			title="Civilian Presence Location";
			description="This logic, defines the areas which should be populated by the dynamic scripts, if enabled in the array. Settings for the amount of waypoints and civilians can be found in ""Scritps\OKS_Dynamic\Settings.sqf""";
			id=1780;
			atlOffset=166.0461;
		};
		class Item25
		{
			dataType="Comment";
			class PositionInfo
			{
				position[]={24694.904,-20.994278,10864.09};
			};
			title="HuntBase Locations";
			description="This logic defines the huntbase locations for a zone, the direction of this logic will also point out where the spawn will be. The spawn positions for huntbases will be located about 20-30m towards the direction of the logic.";
			id=1781;
			atlOffset=166.0461;
		};
		class Item26
		{
			dataType="Comment";
			class PositionInfo
			{
				position[]={24692.457,-21.003906,10760.101};
			};
			title="Objective Locations";
			description="Defines locations for Static Objectives such as Ammo cache, Artillery & Motor pool";
			id=1782;
			atlOffset=166.0461;
		};
		class Item27
		{
			dataType="Comment";
			class PositionInfo
			{
				position[]={24690.348,-20.990694,10661.896};
			};
			title="Compound Strongpoints";
			description="This is the second type of strongpoints used by static infantry contacts. This will fill out a compound (size defined in settings) evenly. Wheras the other strongpoints types will populate a few buidings with more enemies instead.";
			id=1783;
			atlOffset=166.0461;
		};
		class Item28
		{
			dataType="Comment";
			class PositionInfo
			{
				position[]={24690.693,-20.548355,10566.689};
			};
			title="Roadblock Locations";
