						class Item96
						{
							dataType="Object";
							class PositionInfo
							{
								position[]={14633.935,19.244381,16693.189};
								angles[]={0,5.7330227,0};
							};
							side="Empty";
							class Attributes
							{
							};
							id=3677;
							type="acex_intelitems_document";
							atlOffset=0.85688782;
							class CustomAttributes
							{
								class Attribute0
								{
									property="ace_intelitems_data";
									expression="[_this, _value] call ace_intelitems_fnc_setObjectData";
									class Value
									{
										class data
										{
											singleType="STRING";
											value="Logbook Entry – 30 October" \n "They had me down in maintenance tonight, just two levels below where they’re keeping it. Every so often, there’s this deep, gut-churning roar that echoes through the walls. Makes the air feel thick, like it’s vibrating. Last time, the whole complex shook, and you could feel it banging against its cell, trying to get out. I’ve never seen it, but from the noise alone, you’d think it was something out of nightmares." \n "" \n "Rumor has it that this… thing used to be one of the scientists, someone who volunteered for some super-soldier experiment. I don’t know who thought it’d be a good idea to create something like this, or if it’s even right to try. Just because we can make a creature doesn’t mean we should. If there’s a line, we might’ve crossed it already, and I’m not sure anything good is on the other side.";
										};
									};
								};
								nAttributes=1;
							};
						};
