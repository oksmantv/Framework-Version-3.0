						class Item83
						{
							dataType="Object";
							class PositionInfo
							{
								position[]={14681.563,21.928381,16687.189};
								angles[]={0,5.7330227,0};
							};
							side="Empty";
							flags=4;
							class Attributes
							{
							};
							id=3652;
							type="acex_intelitems_document";
							atlOffset=0.00025939941;
							class CustomAttributes
							{
								class Attribute0
								{
									property="ace_intelitems_data";
									expression="[_this, _value] call ace_intelitems_fnc_setObjectData";
									class Value
									{
										class data
										{
											singleType="STRING";
											value="Logbook Entry – 31 October" \n "" \n "It’s past midnight, and I’m alone in the lab, watching the monitors. Subject 4 has been still for hours, yet I can’t shake the sense that it’s aware, watching us back somehow. Today, we pushed its limits further than ever, testing its ability to perceive beyond sensory barriers. The thing… responded. I keep telling myself this is for the greater good—that these studies might lead us to understand, maybe even control, the threat it poses. Progress requires sacrifices, and we’ve committed to seeing this through." \n "" \n "But sometimes I wonder if we’re getting too close, if we’re pushing past what can be contained. The guards think I’m just another scientist meddling in things better left alone, but they don’t know what we’ve seen here. If this creature ever escapes, it could destroy everything. Containment Access Code: 9650";
										};
									};
								};
								nAttributes=1;
							};
						};
						class Item84
						{
							dataType="Object";
							class PositionInfo
							{
								position[]={14688.503,18.373381,16675.451};
								angles[]={0,5.7330227,0};
							};
							side="Empty";
							class Attributes
							{
							};
							id=3666;
							type="acex_intelitems_document";
							atlOffset=0.45599937;
							class CustomAttributes
							{
								class Attribute0
								{
									property="ace_intelitems_data";
									expression="[_this, _value] call ace_intelitems_fnc_setObjectData";
									class Value
									{
										class data
										{
											singleType="STRING";
											value="Logbook Entry – 02 November" \n "" \n "Second night on shift, and already I’m questioning if any paycheck’s worth this. Guarding that thing—it’s not like any other job. You feel it, even behind layers of reinforced glass, pressing into your head like it’s trying to get in. They warned us this would be dangerous, but no one said how close it’d feel. I watch Thompson and the others who’ve been here longer, and it’s clear: this work messes with you." \n "" \n "If anything goes sideways, I’m getting out of here fast. I’ve mapped a quick exit: straight to the service elevator, down to Level Two, and through to the tram station. Once I hit the tram, I’m gone. Elevator code on Sublevel 1 is 0929. Here’s hoping I never need it.";
										};
									};
								};
								nAttributes=1;
							};
						};
