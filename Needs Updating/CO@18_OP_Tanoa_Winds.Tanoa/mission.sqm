						position[]={11400.198,8.6935349,737.75311};
						angles[]={0.78123671,1.2688864,0.4311555};
					};
					title="Small Resupply";
					description="Small resupply crates meant only for a fire-teams resupply. The Ammo Boxes have the standard ammunition for the Squad, the Special Weapons Crate has the secondary ammunitions such as for the roles of MAT, AMAT, AMMG, MMG, Light Rifleman, Marksman.";
					id=1961;
					atlOffset=0.6212635;
				};
				class Item24
				{
					dataType="Comment";
					class PositionInfo
					{
						position[]={11385.202,7.6737218,753.5965};
						angles[]={0,1.110334,0};
					};
					title="Large Resupply";
					description="We're trying to shift away from large resupplies to increase the flow of supplies having to be brought to the front. So we prefer that you use the small crates next to the flag. This exists still if the terrain does not allow for continueous  resupply from AAC.";
					id=1960;
					atlOffset=4.7683716e-007;
				};
