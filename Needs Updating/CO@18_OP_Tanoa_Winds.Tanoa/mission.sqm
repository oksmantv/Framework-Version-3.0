								class data
								{
									singleType="STRING";
									value="The primary leadership of the Rebel wing on the island of Saint-George is located in the village of Tobakoro. In an attempt to force negotiations between the rebels and security forces, we are to attempt to capture as many high-value personell as possible. The village will be heavily guarded, approach with caution and avoid collateral damage.";
