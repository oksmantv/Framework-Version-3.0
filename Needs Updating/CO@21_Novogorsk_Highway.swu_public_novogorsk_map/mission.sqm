						class Item37
						{
							dataType="Comment";
							class PositionInfo
							{
								position[]={4555.5547,266.64114,304.2222};
								angles[]={0.01999305,5.9000053,6.2751918};
							};
							title="BLUFOR Large Resupply";
							description="We're trying to shift away from large resupplies to increase the flow of supplies having to be brought to the front. So we prefer that you use the small crates next to the flag. This exists still if the terrain does not allow for continueous  resupply from AAC.";
							id=1960;
						};
						class Item38
						{
							dataType="Comment";
							class PositionInfo
							{
								position[]={4562.1396,266.90375,288.45883};
								angles[]={0.82146108,1.3233247,0.33559048};
							};
