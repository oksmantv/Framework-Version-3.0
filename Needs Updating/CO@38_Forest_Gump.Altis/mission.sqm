			flags=4;
			class Attributes
			{
				init="[intel1,""Captain Papalous, I need you to send a platoon to hold the high-ground north-west of your position. If they run into contact, attempt to capture one of the CSAT soldiers so we may interrogate him. Transport the prisoners to the Church in Frini where I will be stationed to receive them. Signed Major Achilles""] remoteExec [""ace_intelitems_fnc_setObjectData"",0];";
