				position[]={5114.4941,2.03,991.47614};
				angles[]={0,5.499258,0};
			};
			title="MHQ Paradrop";
			description="This vehicle is used for scripted paradrops that AAC can conduct while flying non-cargo airframes.  The player who requests reinsert can do so at the flag and the pilots can start the drop once they are below 250km/h and above 200m altitude. MHQ paradrop must be enabled in MissionSettings.sqf to work.";
			id=1946;
		};
