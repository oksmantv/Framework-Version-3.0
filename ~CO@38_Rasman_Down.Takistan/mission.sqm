				class Item2
				{
					dataType="Layer";
					name="Destroy House Example";
					class Entities
					{
						items=24;
						class Item0
						{
							dataType="Comment";
							class PositionInfo
							{
								position[]={6326.6616,60.282833,11257.263};
								angles[]={0,0,6.2826972};
							};
							title="Destroy Houses Trigger";
							description="Param 1: Trigger" \n "Param 2: Random damage (True/False)" \n "Param 3: Random Damage (1-10)" \n "" \n "This is a trigger to destroy buildings inside an area to create ruins. Avoid placement of units in buildings that are turned to ruins as they may stand ""inside"" the ruined building if they spawn after it's destruction. This  trigger can be adjusted to fit an entire village or just a portion. Try not to overlap different triggers.";
							id=2835;
						};
						class Item1
						{
							dataType="Trigger";
							position[]={6283.7959,77.617645,11244.824};
							angle=5.3155551;
							class Attributes
							{
								name="DestroyHouseTrigger_1";
								condition="time > 20";
								onActivation="[thisTrigger,false,[8,10]] spawn OKS_Destroy_Houses;";
								sizeA=200;
								sizeB=220;
								isRectangle=1;
								isServerOnly=1;
							};
							id=2832;
							type="EmptyDetectorAreaR250";
							atlOffset=14.21331;
						};
