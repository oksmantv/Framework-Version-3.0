						{
							dataType="Logic";
							class PositionInfo
							{
								position[]={6219.708,60.540874,11152.992};
								angles[]={0.0021001773,0,6.2810569};
							};
							init="(nearestObject [getPos this,""HOUSE""]) setVariable [""OKS_Destroy_Blacklist"",true,true];" \n "(nearestBuilding this) setVariable [""OKS_Destroy_Blacklist"",true,true];";
							id=2833;
							type="Logic";
						};
