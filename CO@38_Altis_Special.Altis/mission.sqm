								class data
								{
									singleType="STRING";
									value="Equipment:" \n "<br/>> Wirecutters are given to R/G/AG roles and can be used to get through the barbed wire at the beach.<br/>> The boats are located on the left/port side of the ship, do not launch both at the same time to avoid collision.<br/><br/>" \n "Support:<br/>" \n "> The USS Liberty will send its missiles against targets on the beach and point bear.<br/>> Do not approach the beach at max speed as you may catch damage from the barrage, look for their trajectories when on the beach to avoid a possible friendly fire accident from the missile strikes.<br/>> Use the Tent MHQ for best possible application of reinsert.";
								};
							};
						};
